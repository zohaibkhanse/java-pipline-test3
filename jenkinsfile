pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                // Pull code from GitHub (update repo URL & branch)
                git branch: 'main', url: 'https://github.com/your-org/your-repo.git'
            }
        }

        stage('Compile') {
            steps {
                // Compile source code
                sh 'mvn clean compile'
            }
        }

        stage('Build') {
            steps {
                // Build project (validate + compile)
                sh 'mvn validate compile'
            }
        }

        stage('Test') {
            steps {
                // Run unit tests
                sh 'mvn test'
            }
        }

        stage('Package') {
            steps {
                // Package into JAR/WAR
                sh 'mvn package'
            }
        }
    }

    post {
        success {
            echo '✅ Maven build pipeline completed successfully!'
        }
        failure {
            echo '❌ Pipeline failed. Check logs for details.'
        }
    }
}
